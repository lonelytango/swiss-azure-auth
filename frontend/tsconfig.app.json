{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@api": ["./src/api"],
      "@api/*": ["./src/api/*"],
      "@auth": ["./src/auth"],
      "@auth/*": ["./src/auth/*"],
      "@components": ["./src/components"],
      "@components/*": ["./src/components/*"],
      "@providers": ["./src/providers"],
      "@providers/*": ["./src/providers/*"],
      "@/types": ["./src/types"],
      "@/types/*": ["./src/types/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
